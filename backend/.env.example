# ============================================================================
# Lit Panel — backend configuration
#
# Copy to backend/.env. EVERYTHING here is OPTIONAL except the LLM key, and even
# that can be set from the in-app Setup page instead. All paths below auto-
# default to folders inside the project, so most users only fill in the key.
# ============================================================================

# --- LLM API key (the only thing most users need) --------------------------
# You can set this here OR in the app's Setup page (stored in macOS Keychain).
# The runtime accepts LLM_API_KEY or the KIMI_API_KEY alias.
LLM_API_KEY=replace_me
# KIMI_API_KEY=replace_me
LLM_API_BASE_URL=https://api.kimi.com/coding/   # defaults to Kimi
LLM_API_MODEL=kimi-for-coding                    # default model
# Aliases also accepted: NBER_API_BASE_URL / NBER_AGENT_MODEL

# --- App shell (optional: branding shown in the UI) ------------------------
# APP_NAME=Research Knowledge Base
# APP_SHORT_NAME=Research KB
# SOURCE_NAME=Your Source

# --- Storage paths (optional: all auto-default to ./Data and ./backend) -----
# Only set these to point at a custom data location.
# KB_DATA_ROOT=/absolute/path/to/Data
# KB_CONTENT_ROOT=/absolute/path/to/Data/knowledge_base
# PAPERS_DIR=/absolute/path/to/Data/papers
# KB_DB_PATH=/absolute/path/to/backend/kb.db

# --- Remote paper discovery (optional: fetch papers by NBER id) -------------
# SUPPORTS_REMOTE_DISCOVERY=true
# REMOTE_DISCOVERY_LABEL=NBER
# REMOTE_SOURCE_KIND=nber
# REMOTE_PDF_URL_TEMPLATE=https://www.nber.org/system/files/working_papers/{pid}/{pid}.pdf
