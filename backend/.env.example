# App shell
APP_NAME=Research Knowledge Base
APP_SHORT_NAME=Research KB
APP_DESCRIPTION=API for searching, browsing, and exporting research paper analysis.
SOURCE_NAME=Your Source
SOURCE_PAPER_LABEL=working papers
PUBLISHER_NAME=Your Organization
SERIES_NAME=Working Papers
PAPER_URL_TEMPLATE=https://example.org/papers/{paper_id}
EXPORT_BASENAME=papers
API_KEY=

# Local storage
KB_DATA_ROOT=/absolute/path/to/Data
KB_CONTENT_ROOT=/absolute/path/to/Data/knowledge_base
PAPERS_DIR=/absolute/path/to/Data/papers
AGENT_DB_PATH=/absolute/path/to/Data/agent_papers.db
AGENTS_DIR=/absolute/path/to/Data/agents
PROJECTS_DIR=/absolute/path/to/Data/knowledge_base/projects
KB_DB_PATH=/absolute/path/to/backend/kb.db
APP_CORS_ORIGINS=http://127.0.0.1:3011

# Remote sync toggle
SUPPORTS_REMOTE_DISCOVERY=false
REMOTE_DISCOVERY_LABEL=Upstream Source
REMOTE_SOURCE_KIND=none
REMOTE_DISCOVERY_API_URL=https://example.org/api/papers
REMOTE_PDF_URL_TEMPLATE=https://example.org/papers/{paper_id}.pdf
EXISTING_AGENT_DB_PATHS=/absolute/path/to/external_agent.db

# Model API (SECRET — never commit a real key; backend/.env is gitignored)
# The key is read from LLM_API_KEY, or the KIMI_API_KEY alias. You can also set
# it at runtime via the in-app Setup page (stored in kb.db, also gitignored).
LLM_API_KEY=replace_me
# KIMI_API_KEY=replace_me            # alias accepted by the runtime
LLM_API_BASE_URL=https://api.kimi.com/coding/
LLM_API_MODEL=kimi-for-coding
# Aliases also accepted: NBER_API_BASE_URL / NBER_AGENT_MODEL, KB_LLM_API_BASE_URL / KB_LLM_MODEL
